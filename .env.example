# PostgreSQL
PGADMIN_EMAIL=admin@yourdomain.com
KC_HOSTNAME=localhost
KEYCLOAK_ADMIN_USER=admin

# Ports (localhost only — no external access)
# หมายเหตุ: ถ้าใช้ Nginx gateway ให้เข้าผ่าน port 443 (HTTPS) แทน
HS_PORT=8080
PGADMIN_PORT=5050
KEYCLOAK_HTTP_PORT=8081
KEYCLOAK_HTTPS_PORT=8443

# Nginx + TLS Gateway
# ถ้ามี domain ให้เปลี่ยน SERVER_NAME เป็น domain จริง
# แล้วรัน certbot เพื่อขอ Let's Encrypt cert
SERVER_NAME=localhost
