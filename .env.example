# ============================================
# Mock STS Environment - Configuration
# ============================================
# คัดลอกไฟล์นี้ไปเป็น .env
# copy .env.example .env
# Docker Compose จะอ่าน .env โดยอัตโนมัติ
#
# ⚠️  ข้อมูล sensitive (รหัสผ่าน) ถูกเก็บใน Docker secrets (/secrets/*.txt)
# ⚠️  ไฟล์ใน /secrets/ และ /certs/ ถูก .gitignore แล้ว
# ⚠️  ดูรหัสผ่านได้จาก secrets/*.txt ใน local machine

# --- PostgreSQL ---
# POSTGRES_DB และ POSTGRES_USER เป็นค่า fixed (STS / userSTS)
# รหัสผ่านอ่านจาก secrets/postgres_password.txt

# --- pgAdmin ---
# รหัสผ่านอ่านจาก secrets/pgadmin_password.txt
# เปลี่ยน email ได้ที่ .env:
PGADMIN_EMAIL=admin@yourdomain.com

# --- Keycloak ---
# รหัสผ่านอ่านจาก secrets/keycloak_password.txt
# เปลี่ยน hostname ได้:
KC_HOSTNAME=localhost
KEYCLOAK_ADMIN_USER=admin

# --- Ports (localhost only) ---
HS_PORT=8080
PGADMIN_PORT=5050
KEYCLOAK_HTTP_PORT=8081
KEYCLOAK_HTTPS_PORT=8443

# --- GitHub Token (optional) ---
GITHUB_TOKEN=ghp_your_token_here
