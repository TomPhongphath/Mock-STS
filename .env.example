# ============================================
# Mock STS Environment - Configuration (.env.example)
# ============================================
# คัดลอกไฟล์นี้ไปเป็น .env แล้วแก้ไขค่าตามต้องการ
# copy .env.example .env
# Docker Compose จะอ่าน .env โดยอัตโนมัติ

# --- PostgreSQL ---
POSTGRES_DB=STS
POSTGRES_USER=userSTS
POSTGRES_PASSWORD=S@mart@2024
PG_UAT_PORT=5431
PG_MASTER_PORT=5432

# --- Headscale ---
HS_PORT=8080

# --- pgAdmin ---
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@yourdomain.com
PGADMIN_PASSWORD=PgAdminSecurePass123!

# --- Keycloak ---
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=KeycloakSecurePass123!

# --- GitHub Token (optional) ---
GITHUB_TOKEN=ghp_your_token_here
